# Talk To Data v3 - Backend Environment Variables

# Application
DEBUG=true
APP_NAME="Talk To Data"
APP_VERSION="3.0.0"

# Database (PostgreSQL)
DATABASE_URL=postgresql://ttd:ttd@localhost:5432/talktodata

# File Upload
MAX_UPLOAD_SIZE_MB=100

# LLM Configuration (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Default LLM
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# Query Limits
MAX_QUERY_ROWS=10000
QUERY_TIMEOUT_SECONDS=30
